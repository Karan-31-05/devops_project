# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here

# Database (if using local SQLite, can leave empty for PostgreSQL from dj_database_url)
# DATABASE_URL=postgresql://user:password@localhost:5432/erp_db

# Email Configuration
EMAIL_HOST_USER=your-gmail-account@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here

# Moodle LMS Integration
MOODLE_BASE_URL=https://your-moodle-instance.com
MOODLE_API_TOKEN=your-moodle-api-token-here
